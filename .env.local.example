# ============================================
# STABENA - Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================

# ── Supabase ─────────────────────────────────
# Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# ── Brevo (emails transactionnels) ───────────
# https://app.brevo.com > SMTP & API > API Keys
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=supportstabena@gmail.com

# ── Stripe (paiement en ligne) ───────────────
# https://dashboard.stripe.com > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...

# ── Site URL ─────────────────────────────────
# En local: http://localhost:3000
# En production: https://votre-domaine.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cron secret (anniversaires) ──────────────
# Générez une chaîne aléatoire longue et unique
# Ex: openssl rand -hex 32
CRON_SECRET=une_chaine_aleatoire_longue_et_secrete

# ============================================
# CRÉER UN COMPTE ADMIN
# 1. Inscrivez-vous normalement sur le site
# 2. Supabase > Table Editor > profiles
# 3. Changez le champ "role" de "user" à "admin"
# ============================================
